extends ../../layouts/default

block content
  .container.py-5
    h2.font-headline.fw-black.mb-4 Sản phẩm đã mua

    if products.length === 0
      p.text-secondary.opacity-75 Bạn chưa mua sản phẩm nào.

    else
      .row.g-4
        each product in products
          .col-12.col-md-6.col-lg-4
            .card.border-0.rounded-4.shadow-sm.h-100
              img.card-img-top.rounded-top-4(src=product.image alt=product.name style="object-fit:cover;height:200px")
              .card-body
                h5.card-title.font-headline.fw-bold= product.name
                p.text-primary.fw-bold= product.price.toLocaleString('vi-VN') + 'đ'
                a.btn.btn-outline-primary.rounded-pill.w-100(href=`/product/${product._id}`) Xem chi tiết