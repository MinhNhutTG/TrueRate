.col.product-card(data-category=product.category)
  .card.h-100.border-0.bg-surface-container-low.rounded-4xl.overflow-hidden.shadow-sm.hover-scale
    .ratio.ratio-1x1.bg-white
      img.w-100.h-100.object-fit-cover(src=product.image, alt=product.name)
    .card-body.p-4.d-flex.flex-column
      p.fs-9.fw-bold.text-primary.text-uppercase.mb-2= product.category
      h3.h6.fw-bold.mb-2(style="min-height:48px;")= product.name
      .mb-3.text-warning.fs-7
        span ★★★★☆
        span.text-muted.ms-2 (4.0)
      .mt-auto.d-flex.justify-content-between.align-items-center
        span.fw-bold.fs-6.text-dark= product.price.toLocaleString() + "đ"
        a.text-primary.text-decoration-none.fw-semibold(href=`/product/${product._id}`) Xem chi tiết