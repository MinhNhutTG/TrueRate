nav.fixed-top.w-100.glass-nav.shadow-sm
  .container.d-flex.justify-content-between.align-items-center.px-4.py-3
    //- Left
    .d-flex.align-items-center.gap-4
      a.text-2xl.font-black.tracking-tight.text-primary.font-headline.text-decoration-none(href="/") BlockRate
      .d-none.d-md-flex.align-items-center.gap-4
        a.text-primary.font-bold.border-bottom.border-2.border-primary.font-headline.fs-7.text-decoration-none(href="/home") Trang chủ

    //- Right
    .d-flex.align-items-center.gap-3
      if currentUser
        .d-flex.align-items-center.gap-3
          .user-menu.d-flex.align-items-center.gap-2
            a.user-info.d-flex.align-items-center.gap-2.text-decoration-none(
              href="/profile/purchased-list"
            )
              .user-avatar #{currentUser.fullName.charAt(0).toUpperCase()}
              span.user-name #{currentUser.fullName}

            button#logoutBtn.user-logout(type="button")
              span.material-symbols-outlined logout
      else
        a.px-3.py-2.text-secondary.font-headline.fs-7.text-decoration-none.rounded-pill(href="/login") Đăng nhập
        

      button#mobile-menu-btn.d-md-none.p-2.text-secondary.border-0.bg-transparent.rounded-circle
        span.material-symbols-outlined menu

  //- Mobile Menu
  #mobile-menu.d-none.d-md-none.position-absolute.top-100.start-0.w-100.bg-white.shadow-lg.border-top.p-4
    a.d-block.text-secondary.font-bold.text-decoration-none(href="/home") Trang chủ
   
    hr.my-3
    if currentUser
      .d-flex.align-items-center.justify-content-between
        span.text-secondary.font-bold #{currentUser.fullName}
        button#logoutBtnMobile.text-danger.font-bold.border-0.bg-transparent Đăng xuất
    else
      a.d-block.text-primary.font-bold.text-decoration-none(href="/login") Đăng nhập
      

script.
  // Logout desktop
  const logoutBtn = document.getElementById('logoutBtn')
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' })
      window.location.href = '/'
    })
  }

  // Logout mobile
  const logoutBtnMobile = document.getElementById('logoutBtnMobile')
  if (logoutBtnMobile) {
    logoutBtnMobile.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' })
      window.location.href = '/'
    })
  }

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('d-none')
    })
  }